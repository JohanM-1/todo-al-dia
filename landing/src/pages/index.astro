---
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale, landingContent } from '../config/i18n';
import { siteConfig } from '../config/site';

const appUrl = siteConfig.appUrl;
const content = landingContent[defaultLocale];
const title = content.seo.title;
const description = content.seo.description;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'TodoAlDía',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Android, Web',
  inLanguage: 'en',
  description,
  url: 'https://todoaldia.app/',
  downloadUrl: appUrl,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'COP',
  },
  potentialAction: {
    '@type': 'ViewAction',
    name: content.ctas.app,
    target: appUrl,
  },
  featureList: content.structuredData.featureList,
};
---

<BaseLayout title={title} description={description} canonical="/" lang={content.htmlLang} structuredData={structuredData}>
  <a id="skip-link" class="skip-link" href="#contenido">{content.a11y.skipToContent}</a>

  <header class="site-header">
    <div class="container header-inner">
      <a id="brand-link" class="brand" href="#top" aria-label={content.a11y.brandHome}>
        <span class="brand-mark" aria-hidden="true">TD</span>
        <span>TodoAlDía</span>
      </a>

      <nav id="main-nav" aria-label={content.a11y.mainNav}>
        <ul class="nav-list">
          <li><a id="nav-how-it-works" href="#como-funciona">{content.nav.howItWorks}</a></li>
          <li><a id="nav-faq" href="#preguntas">{content.nav.faq}</a></li>
        </ul>
      </nav>

      <div class="header-actions">
        <div id="locale-switcher" class="locale-switcher" aria-label={content.a11y.localeSwitcher}>
          <button class="locale-button" type="button" data-locale-button="en">EN</button>
          <button class="locale-button" type="button" data-locale-button="es">ES</button>
        </div>

        <a
          class="button button-primary header-cta"
          href={appUrl}
          data-analytics="cta-primary-header"
          data-destination={content.analytics.destinationLabel}
          data-cta="header"
        >
          {content.ctas.appShort}
        </a>
      </div>
    </div>
  </header>

  <main id="contenido">
    <section class="hero section" id="top">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p id="hero-eyebrow" class="eyebrow">{content.hero.eyebrow}</p>
          <h1 id="hero-title">{content.hero.title}</h1>
          <p id="hero-lead" class="lead">{content.hero.lead}</p>

          <div id="hero-actions" class="hero-actions" aria-label={content.a11y.heroActions}>
            <a
              class="button button-primary button-large"
              href={appUrl}
              data-analytics="cta-primary-hero"
              data-destination={content.analytics.destinationLabel}
              data-cta="hero"
            >
              {content.ctas.app}
            </a>
            <a id="cta-see-how" class="text-link" href="#como-funciona" data-analytics="cta-secondary-how-it-works">
              {content.ctas.seeHow}
            </a>
          </div>

          <p id="hero-microcopy" class="microcopy">{content.hero.microcopy}</p>
        </div>

        <aside class="funnel-card" aria-labelledby="funnel-title">
          <img id="hero-preview" class="hero-preview" src="/hero-preview.svg" alt={content.a11y.heroPreviewAlt} loading="eager" />
          <p id="sidecard-badge" class="status-badge">{content.sideCard.badge}</p>
          <h2 id="funnel-title">{content.sideCard.title}</h2>
          <p id="sidecard-body">{content.sideCard.body}</p>

          <ul id="checkpoint-list" class="checkpoint-list" aria-label={content.a11y.checkpoints}>
            {content.sideCard.checkpoints.map((checkpoint) => (
              <li>
                <strong>{checkpoint.label}:</strong> {checkpoint.text}
              </li>
            ))}
          </ul>

          <div id="sidecard-pills" class="inline-proof" role="list" aria-label={content.a11y.pills}>
            {content.sideCard.pills.map((pill) => (
              <span role="listitem">{pill}</span>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="section" aria-labelledby="resultados-title">
      <div class="container">
        <div class="section-heading">
          <p id="benefits-eyebrow" class="eyebrow">{content.benefits.eyebrow}</p>
          <h2 id="resultados-title">{content.benefits.title}</h2>
          <p id="benefits-intro">{content.benefits.intro}</p>
        </div>

        <div id="benefits-grid" class="card-grid">
          {content.benefits.items.map((item) => (
            <article class="info-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-alt" aria-labelledby="prueba-title">
      <div class="container proof-layout">
        <div class="section-heading compact">
          <p id="features-eyebrow" class="eyebrow">{content.features.eyebrow}</p>
          <h2 id="prueba-title">{content.features.title}</h2>
          <p id="features-intro">{content.features.intro}</p>
        </div>

        <ul id="features-list" class="proof-list">
          {content.features.points.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section" id="como-funciona" aria-labelledby="como-funciona-title">
      <div class="container">
        <div class="section-heading">
          <p id="steps-eyebrow" class="eyebrow">{content.steps.eyebrow}</p>
          <h2 id="como-funciona-title">{content.steps.title}</h2>
          <p id="steps-intro">{content.steps.intro}</p>
        </div>

        <ol id="steps-list" class="step-list">
          {content.steps.items.map((step) => (
            <li class="step-card">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </li>
          ))}
        </ol>

        <div class="feedback-panel" aria-labelledby="feedback-title">
          <h3 id="feedback-title">{content.steps.panel.title}</h3>
          <p id="feedback-body">{content.steps.panel.body}</p>
          <ul id="feedback-list">
            {content.steps.panel.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section" id="preguntas" aria-labelledby="preguntas-title">
      <div class="container faq-shell">
        <div class="section-heading compact">
          <p id="faq-eyebrow" class="eyebrow">{content.faq.eyebrow}</p>
          <h2 id="preguntas-title">{content.faq.title}</h2>
        </div>

        <div id="faq-list" class="faq-list">
          {content.faq.items.map((faq) => (
            <article class="faq-card">
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-alt" id="cta" aria-labelledby="cta-title">
      <div class="container cta-box">
        <div>
          <p id="closing-eyebrow" class="eyebrow">{content.closing.eyebrow}</p>
          <h2 id="cta-title">{content.closing.title}</h2>
          <p id="closing-body">{content.closing.body}</p>
        </div>

        <div class="cta-actions">
          <a
            class="button button-primary button-large"
            href={appUrl}
            data-analytics="cta-primary-bottom"
            data-destination={content.analytics.destinationLabel}
            data-cta="bottom"
          >
            {content.ctas.app}
          </a>
          <a id="cta-back-to-top" class="text-link" href="#top" data-analytics="cta-secondary-back-to-top">{content.ctas.backToTop}</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p>TodoAlDía</p>
      <p id="footer-tagline">{content.footer.tagline}</p>
    </div>
  </footer>

  <script
    is:inline
    define:vars={{
      translations: landingContent,
      defaultLocale,
    }}
  >
    const storageKey = 'todoaldia:landing-locale';

    function resolveLocale(value) {
      const normalized = value?.trim().toLowerCase();

      if (!normalized) {
        return defaultLocale;
      }

      if (normalized === 'es' || normalized.startsWith('es-')) {
        return 'es';
      }

      return 'en';
    }

    function detectLocale() {
      const params = new URLSearchParams(window.location.search);
      const queryLocale = params.get('lang');

      if (queryLocale) {
        return resolveLocale(queryLocale);
      }

      const storedLocale = window.localStorage.getItem(storageKey);

      if (storedLocale) {
        return resolveLocale(storedLocale);
      }

      const browserLocales = [...(navigator.languages || []), navigator.language].filter(Boolean);

      for (const locale of browserLocales) {
        const resolved = resolveLocale(locale);

        if (resolved === 'es') {
          return 'es';
        }
      }

      return defaultLocale;
    }

    function setText(id, value) {
      const node = document.getElementById(id);

      if (node) {
        node.textContent = value;
      }
    }

    function setAttr(id, attribute, value) {
      const node = document.getElementById(id);

      if (node) {
        node.setAttribute(attribute, value);
      }
    }

    function renderCheckpoints(items) {
      const list = document.getElementById('checkpoint-list');

      if (!list) {
        return;
      }

      list.replaceChildren(
        ...items.map((item) => {
          const li = document.createElement('li');
          const strong = document.createElement('strong');

          strong.textContent = `${item.label}:`;
          li.append(strong, ` ${item.text}`);

          return li;
        }),
      );
    }

    function renderPills(items) {
      const list = document.getElementById('sidecard-pills');

      if (!list) {
        return;
      }

      list.replaceChildren(
        ...items.map((item) => {
          const span = document.createElement('span');

          span.setAttribute('role', 'listitem');
          span.textContent = item;

          return span;
        }),
      );
    }

    function renderCards(containerId, items, cardClass) {
      const container = document.getElementById(containerId);

      if (!container) {
        return;
      }

      container.replaceChildren(
        ...items.map((item) => {
          const article = document.createElement('article');
          const title = document.createElement('h3');
          const description = document.createElement('p');

          article.className = cardClass;
          title.textContent = item.title;
          description.textContent = item.description;
          article.append(title, description);

          return article;
        }),
      );
    }

    function renderStringList(containerId, items) {
      const container = document.getElementById(containerId);

      if (!container) {
        return;
      }

      container.replaceChildren(
        ...items.map((item) => {
          const li = document.createElement('li');

          li.textContent = item;
          return li;
        }),
      );
    }

    function renderFaqs(items) {
      const container = document.getElementById('faq-list');

      if (!container) {
        return;
      }

      container.replaceChildren(
        ...items.map((item) => {
          const article = document.createElement('article');
          const question = document.createElement('h3');
          const answer = document.createElement('p');

          article.className = 'faq-card';
          question.textContent = item.question;
          answer.textContent = item.answer;
          article.append(question, answer);

          return article;
        }),
      );
    }

    function setMeta(selector, value) {
      const node = document.querySelector(selector);

      if (node) {
        node.setAttribute('content', value);
      }
    }

    function updateLocaleButtons(locale) {
      document.querySelectorAll('[data-locale-button]').forEach((button) => {
        const isActive = button.getAttribute('data-locale-button') === locale;

        button.setAttribute('aria-pressed', String(isActive));
        button.toggleAttribute('data-active', isActive);
      });
    }

    function applyLocale(locale, persist = true) {
      const copy = translations[locale] || translations[defaultLocale];

      document.documentElement.lang = copy.htmlLang;
      document.title = copy.seo.title;

      setMeta('meta[name="description"]', copy.seo.description);
      setMeta('meta[property="og:title"]', copy.seo.title);
      setMeta('meta[property="og:description"]', copy.seo.description);
      setMeta('meta[property="og:locale"]', copy.htmlLang.startsWith('es') ? 'es_AR' : 'en_US');
      setMeta('meta[name="twitter:title"]', copy.seo.title);
      setMeta('meta[name="twitter:description"]', copy.seo.description);

      setText('skip-link', copy.a11y.skipToContent);
      setAttr('brand-link', 'aria-label', copy.a11y.brandHome);
      setAttr('main-nav', 'aria-label', copy.a11y.mainNav);
      setAttr('locale-switcher', 'aria-label', copy.a11y.localeSwitcher);
      setAttr('hero-preview', 'alt', copy.a11y.heroPreviewAlt);
      setAttr('hero-actions', 'aria-label', copy.a11y.heroActions);
      setAttr('checkpoint-list', 'aria-label', copy.a11y.checkpoints);
      setAttr('sidecard-pills', 'aria-label', copy.a11y.pills);
      setText('nav-how-it-works', copy.nav.howItWorks);
      setText('nav-faq', copy.nav.faq);
      setText('hero-eyebrow', copy.hero.eyebrow);
      setText('hero-title', copy.hero.title);
      setText('hero-lead', copy.hero.lead);
      setText('cta-see-how', copy.ctas.seeHow);
      setText('hero-microcopy', copy.hero.microcopy);
      setText('sidecard-badge', copy.sideCard.badge);
      setText('funnel-title', copy.sideCard.title);
      setText('sidecard-body', copy.sideCard.body);
      setText('benefits-eyebrow', copy.benefits.eyebrow);
      setText('resultados-title', copy.benefits.title);
      setText('benefits-intro', copy.benefits.intro);
      setText('features-eyebrow', copy.features.eyebrow);
      setText('prueba-title', copy.features.title);
      setText('features-intro', copy.features.intro);
      setText('steps-eyebrow', copy.steps.eyebrow);
      setText('como-funciona-title', copy.steps.title);
      setText('steps-intro', copy.steps.intro);
      setText('feedback-title', copy.steps.panel.title);
      setText('feedback-body', copy.steps.panel.body);
      setText('faq-eyebrow', copy.faq.eyebrow);
      setText('preguntas-title', copy.faq.title);
      setText('closing-eyebrow', copy.closing.eyebrow);
      setText('cta-title', copy.closing.title);
      setText('closing-body', copy.closing.body);
      setText('cta-back-to-top', copy.ctas.backToTop);
      setText('footer-tagline', copy.footer.tagline);

      document.querySelectorAll('[data-cta="header"]').forEach((node) => {
        node.textContent = copy.ctas.appShort;
        node.setAttribute('data-destination', copy.analytics.destinationLabel);
      });

      document.querySelectorAll('[data-cta="hero"], [data-cta="bottom"]').forEach((node) => {
        node.textContent = copy.ctas.app;
        node.setAttribute('data-destination', copy.analytics.destinationLabel);
      });

      renderCheckpoints(copy.sideCard.checkpoints);
      renderPills(copy.sideCard.pills);
      renderCards('benefits-grid', copy.benefits.items, 'info-card');
      renderStringList('features-list', copy.features.points);
      renderCards('steps-list', copy.steps.items, 'step-card');
      renderStringList('feedback-list', copy.steps.panel.points);
      renderFaqs(copy.faq.items);
      updateLocaleButtons(locale);

      if (persist) {
        window.localStorage.setItem(storageKey, locale);
      }
    }

    const activeLocale = detectLocale();
    applyLocale(activeLocale, false);

    document.querySelectorAll('[data-locale-button]').forEach((button) => {
      button.addEventListener('click', () => {
        applyLocale(button.getAttribute('data-locale-button'));
      });
    });
  </script>
</BaseLayout>
